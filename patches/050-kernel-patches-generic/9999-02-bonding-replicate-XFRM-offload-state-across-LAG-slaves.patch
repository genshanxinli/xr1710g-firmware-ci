+static struct net_device *bond_ipsec_lag_xmit_dev(struct bonding *bond,
+						  struct xfrm_state *xs)
+{
+	struct bond_up_slave *slaves;
+	unsigned int count;
+	unsigned int start;
+	unsigned int i;
